rules_version = '2';

// Deploy with: firebase deploy --only firestore:rules
//
// Quiz-taking writes (attempts, session updates) go through the Next.js API
// routes using the Admin SDK, which bypasses these rules. The rules therefore
// lock those collections down for direct client access.
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && get(/databases/$(database)/documents/profiles/$(request.auth.uid)).data.role == 'admin';
    }

    match /profiles/{userId} {
      // Users read their own profile; admins can read everyone's.
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Users may create their own profile, but only as a teacher —
      // admin roles are granted out-of-band (console / Admin SDK).
      allow create: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == 'teacher';
      // No self-service role escalation.
      allow update: if isSignedIn()
        && request.auth.uid == userId
        && request.resource.data.role == resource.data.role;
      allow delete: if false;
    }

    match /questions/{questionId} {
      // Questions contain the answer key, so teachers never read them
      // directly — the API serves sanitised copies. Admins manage the bank
      // through the client SDK.
      allow read, write: if isAdmin();
    }

    match /attempts/{attemptId} {
      // Owners and admins can review attempts; only the server writes them
      // (scores are computed server-side and must not be forgeable).
      allow read: if isSignedIn()
        && (resource.data.teacherId == request.auth.uid || isAdmin());
      allow write: if false;
    }

    match /quizSessions/{sessionId} {
      // Owners and admins can read sessions; only the server creates and
      // updates them.
      allow read: if isSignedIn()
        && (resource.data.teacherId == request.auth.uid || isAdmin());
      allow write: if false;
    }
  }
}
