NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Server-side (Admin SDK) credentials for the API routes. Paste the full JSON
# of a Firebase service account key (Project settings → Service accounts →
# Generate new private key). Alternatively leave unset and provide Application
# Default Credentials (e.g. GOOGLE_APPLICATION_CREDENTIALS).
FIREBASE_SERVICE_ACCOUNT_KEY=
